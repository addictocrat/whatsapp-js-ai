datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Instruction {
  id        Int      @id @default(autoincrement())
  name      String
  content   String
  modelName String?
  isActive  Boolean  @default(false)
  phoneNumbers PhoneNumber[]
}

model DailyChat {
  id           String    @id
  date         String
  senderPhone  String
  firstMessage String
  messages     Message[]
}

model Message {
  id          Int       @id @default(autoincrement())
  dailyChatId String
  body        String
  sender      String
  timestamp   DateTime  @default(now())
  dailyChat   DailyChat @relation(fields: [dailyChatId], references: [id], onDelete: Cascade)
}

model CronTask {
  id        Int       @id @default(autoincrement())
  name      String
  pattern   String?
  executeAt DateTime?
  isOneTime Boolean   @default(false)
  timezone  String    @default("Europe/Istanbul")
  prompt    String
  modelName String?
  isActive  Boolean   @default(true)
}

model PhoneNumber {
  id              Int          @id @default(autoincrement())
  number          String       @unique
  modelName       String?
  instructionId   Int?
  instruction     Instruction? @relation(fields: [instructionId], references: [id], onDelete: SetNull)
  allowGroupChats Boolean      @default(false)
  isEnabled       Boolean      @default(true)
  responseDelay   Int          @default(0)
}

model Settings {
  id           Int     @id @default(1)
  contextCount Int     @default(8)
  isPaused     Boolean @default(false)
}
